# ===== 系统基础配置 =====
APP_NAME=CryptoAssistant
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 数据库配置 =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crypto_assistant
DATABASE_ECHO=false

# ===== Redis配置 =====
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ===== Binance交易所配置 =====
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_TESTNET=true
# REST use_proxy=True 时：若 BINANCE_PROXY_ENABLED=true 且 BINANCE_PROXY_URL 非空则优先（与代码默认 http://127.0.0.1:7890 一致，可改）；否则使用 HTTPS_PROXY/HTTP_PROXY
BINANCE_PROXY_ENABLED=false
BINANCE_PROXY_URL=http://127.0.0.1:7890

# ===== OpenAI配置 =====
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== 模块开关 =====
MODULE_AI_ENABLED=false
MODULE_TRADINGVIEW_ENABLED=false
MODULE_EXECUTION_ENABLED=false
MODULE_BACKTEST_ENABLED=true

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===== 前端配置 =====
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===== 默认管理员 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@example.com
